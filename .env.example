# Samard's Recipe Finder - Environment Configuration
# Copy this file to .env and fill in your API keys

# Spoonacular API Key (required for full recipe database)
# Get your free key at: https://spoonacular.com/food-api
# Free tier: 150 requests per day
SPOONACULAR_API_KEY=your_api_key_here

# Note: RecipePuppy and TheMealDB don't require API keys
